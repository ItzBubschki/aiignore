{
  "name": "@aiignore/cli",
  "version": "0.1.1",
  "description": "Protect sensitive files from AI coding assistants with .aiignore",
  "type": "module",
  "bin": {
    "aiignore": "dist/cli.js",
    "ai-guard": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "preuninstall": "aiignore uninstall"
  },
  "keywords": [
    "ai",
    "aiignore",
    "claude",
    "security",
    "gitignore",
    "hooks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItzBubschki/aiignore.git"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ignore": "^7.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
